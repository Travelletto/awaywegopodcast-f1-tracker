# Server Configuration
PORT=3000
NODE_ENV=production

# MailerLite Integration (optional)
# Get your API key from: https://dashboard.mailerlite.com/integrations/api
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=

# MailerLite Webhook Security (optional)
# Set a random secret string here and include it in webhook headers
MAILERLITE_WEBHOOK_SECRET=
